# MemoDrop Environment Configuration

# 1. LLM API Key (Required for routing and entity extraction)
GROQ_API_KEY=your_groq_api_key_here

# 2. Embedding API Key (Optional, fallback uses local Jaccard/TF-IDF similarity)
# Gemini text-embedding-004 is recommended and free.
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Supabase Configuration (Optional, fallback uses local SQLite database)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key


